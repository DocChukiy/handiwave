# Browser-visible Vite variables.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_PAYMENT_CALLBACK_URL=https://your-domain.com/payment/callback

# Supabase Edge Function secrets are not read by Vite.
# Set these with `supabase secrets set ...` instead of putting live values here:
# PAYSTACK_SECRET_KEY=sk_test_xxx
# PAYSTACK_CALLBACK_URL=https://your-domain.com/payment/callback
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
